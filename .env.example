DATABASE_URL=sqlite:./data/ctf_maze.db
RUST_LOG=info
# Optional log format: pretty (default) or json
# LOG_FORMAT=pretty
# Backend port (default 8080)
PORT=8080
# Production: comma-separated CORS origin allowlist
# ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
# Escape hatch for controlled staging only (release builds)
# CORS_PERMISSIVE=false
# Global rate limit defaults (per IP): keep dev generous, tighten in production as needed
RATE_LIMIT_PER_SECOND=20
RATE_LIMIT_BURST=40
# Stricter limits for expensive endpoints (POST /api/solve and /api/maze/generate)
RATE_LIMIT_EXPENSIVE_PER_SECOND=5
RATE_LIMIT_EXPENSIVE_BURST=10
# Proxy trust for rate limiting key extraction:
# false -> peer socket IP only (safe default)
# true  -> use forwarded headers (x-forwarded-for/x-real-ip/forwarded) via SmartIpKeyExtractor
#         only enable behind trusted proxies that overwrite/strip spoofed headers
TRUST_PROXY=false
# Frontend: set in web/.env.local
NEXT_PUBLIC_API_URL=http://localhost:8080
