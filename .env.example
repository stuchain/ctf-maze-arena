DATABASE_URL=sqlite:./data/ctf_maze.db
RUST_LOG=info
# Backend port (default 8080)
PORT=8080
# Production: comma-separated CORS origin allowlist
# ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
# Escape hatch for controlled staging only (release builds)
# CORS_PERMISSIVE=false
# Global rate limit defaults (per IP): keep dev generous, tighten in production as needed
RATE_LIMIT_PER_SECOND=20
RATE_LIMIT_BURST=40
# Frontend: set in web/.env.local
NEXT_PUBLIC_API_URL=http://localhost:8080
